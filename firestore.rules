rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Return true if user is signed in and matches the owner of the document path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Validate generic ID parameters to be secure
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Auth Config rules (salt & verification hash)
      match /auth_config/{configId} {
        allow read, write: if isOwner(userId) && isValidId(configId);
      }

      // Vault Credentials list rules
      match /vault_entries/{entryId} {
        allow read, write: if isOwner(userId) && isValidId(entryId);
      }

      // Secure Notes list rules
      match /secure_notes/{noteId} {
        allow read, write: if isOwner(userId) && isValidId(noteId);
      }

      // User Settings configurations
      match /settings/{settingsId} {
        allow read, write: if isOwner(userId) && isValidId(settingsId);
      }
    }
  }
}
